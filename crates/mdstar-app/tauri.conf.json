{
  "productName": "MD Star",
  "version": "0.1.0",
  "identifier": "dev.mdstar.desktop",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MD Star",
        "dragDropEnabled": true,
        "width": 1120,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 23
        },
        "backgroundColor": "#00000000",
        "transparent": true,
        "decorations": true,
        "center": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "MD Star Contributors",
    "copyright": "Copyright © 2026 MD Star Contributors",
    "category": "Productivity",
    "icon": ["icons/icon.png"],
    "shortDescription": "A fast, beautiful Markdown reader and editor",
    "longDescription": "MD Star is a native macOS Markdown viewer with live preview, mermaid diagrams, and a built-in editor.",
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "contentTypes": [
          "net.daringfireball.markdown",
          "public.markdown",
          "public.plain-text"
        ],
        "name": "Markdown",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": ["txt"],
        "contentTypes": ["public.plain-text"],
        "name": "Plain Text (Markdown)",
        "description": "Plain Text Document",
        "mimeType": "text/plain",
        "role": "Viewer",
        "rank": "Alternate"
      },
      {
        "ext": ["json", "xml", "yaml", "yml", "toml", "csv"],
        "contentTypes": ["public.text", "public.plain-text"],
        "name": "Structured Text (MD Star)",
        "description": "Structured text document",
        "mimeType": "text/plain",
        "role": "Viewer",
        "rank": "Alternate"
      },
      {
        "ext": ["rs", "kt", "kts", "py", "js", "jsx", "ts", "tsx", "java", "go", "c", "h", "cpp", "hpp", "cs", "swift", "sh", "bash", "zsh", "ini", "conf", "sql", "log"],
        "contentTypes": ["public.text", "public.plain-text"],
        "name": "Source Code (MD Star)",
        "description": "Source code document",
        "mimeType": "text/plain",
        "role": "Viewer",
        "rank": "Alternate"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "entitlements": null
    }
  }
}
